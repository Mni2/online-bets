# --- Core ---
NODE_ENV=development
LOG_LEVEL=info

# --- Backend ---
BACKEND_PORT=4000
BACKEND_PUBLIC_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# --- Frontend ---
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Admin ---
ADMIN_PORT=5173
VITE_API_URL=http://localhost:4000

# --- Database (Prisma) ---
DATABASE_URL=postgresql://nova:nova@localhost:5432/nova_royale?schema=public

# --- Auth ---
JWT_ACCESS_SECRET=replace_me_with_long_random_string_min_32
JWT_REFRESH_SECRET=replace_me_with_another_long_random_string
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
BCRYPT_ROUNDS=12

# --- Provably-fair RNG ---
PROVABLY_FAIR_SERVER_SEED=change_me_each_round_or_use_hmac_rotation
PROVABLY_FAIR_HMAC_KEY=change_me_per_session

# --- Wallet ---
DEFAULT_CURRENCY=USD
HOUSE_EDGE_BPS=150

# --- Payments (Stripe placeholders) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Mail / Notifications ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
