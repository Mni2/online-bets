{
  "name": "casino-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Nova Royale — modular, enterprise-grade online casino platform",
  "license": "UNLICENSED",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "dev:backend": "npm run dev --workspace apps/backend",
    "dev:frontend": "npm run dev --workspace apps/frontend",
    "dev:admin": "npm run dev --workspace apps/admin",
    "db:generate": "npm run prisma:generate --workspace packages/database",
    "db:migrate": "npm run prisma:migrate --workspace packages/database",
    "db:seed": "npm run prisma:seed --workspace packages/database"
  },
  "engines": {
    "node": ">=20.10.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "typescript": "5.4.5",
    "@types/node": "20.12.7",
    "eslint": "8.57.0",
    "prettier": "3.2.5"
  }
}
